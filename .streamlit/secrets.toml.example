# Copy this file to .streamlit/secrets.toml for local development,
# or paste its contents into the "Secrets" box in the Streamlit Community
# Cloud app settings for deployment. Do NOT commit a real secrets.toml.

# Supabase Postgres connection string.
# In Supabase: Project Settings > Database > Connection string > URI
# (use the "Session pooler" host/port for Streamlit Cloud).
# Rewrite the scheme from postgresql:// to postgresql+psycopg2:// as shown.
DATABASE_URL = "postgresql+psycopg2://postgres:YOUR_PASSWORD@YOUR_HOST:5432/postgres"

# Named users with simple role-based access.
# Roles: admin, technical, viewer
[users.admin]
password = "changeme"
display_name = "Stefan Hermes"
role = "admin"

[users.tech1]
password = "changeme2"
display_name = "Technical User"
role = "technical"

[users.viewer1]
password = "changeme3"
display_name = "Viewer"
role = "viewer"
